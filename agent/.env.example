# --- GCP authentication ---
# Use a real Gemini API key for live results, or keep the default for stub responses
GOOGLE_API_KEY=test-api-key-returns-dummy-response

# --- Security secrets ---
# Must match PROXY_AUTH_TOKEN set in frontend/.env
PROXY_AUTH_TOKEN=local-dev-token

# Cloudflare Turnstile server-side secret
# Use Cloudflare always-pass test secret for local dev
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- Database (topic preferences persistence) — REQUIRED ---
# The app has no in-memory / SQLite fallback. Start the bundled Postgres
# container first:
#
#   docker compose up -d postgres
#
# The URL below matches docker-compose.yml credentials.
DATABASE_URL=postgresql+asyncpg://mapme:mapme@localhost:5432/mapme

# --- Optional model override ---
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
