# Cloud Run Agent API URL
# Production: set to your Cloud Run service URL
# Local dev: defaults to http://localhost:8080
AGENT_API_URL=http://localhost:8080

# Shared secret — must match PROXY_AUTH_TOKEN on the Cloud Run service
PROXY_AUTH_TOKEN=local-dev-token

# Cloudflare Turnstile public site key
# Production: use your PROD site key
# Local dev: use Cloudflare always-pass test key
TURNSTILE_SITE_KEY=1x00000000000000000000AA
